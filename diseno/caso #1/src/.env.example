# Azure Entra ID (Authentication)
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Azure Key Vault
AZURE_KEYVAULT_URL=https://customsidentityserver.vault.azure.net/

# Azure Application Insights
NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING=your-connection-string

# API Configuration
API_BASE_URL=http://localhost:8080/api
NOTIFICATION_CALLBACK_URL=http://localhost:3000/api/notifications/callback

# Environment
NODE_ENV=development
NEXT_PUBLIC_ENVIRONMENT=development
